{
  "manifest_version": 3,
  "name": "Prompt Evaluator",
  "version": "1.0.0",
  "description": "Real-time prompt quality evaluation with radar chart",
  "permissions": ["storage"],
  "host_permissions": ["https://api.mistral.ai/*", "http://localhost:*/*", "http://127.0.0.1:*/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.mistral.ai/*"
      ],
      "js": [
        "shared/constants.js",
        "shared/config.js",
        "shared/scoring.js",
        "shared/i18n.js",
        "shared/prompts.js",
        "content/sites/chatgpt.js",
        "content/sites/claude.js",
        "content/sites/gemini.js",
        "content/sites/mistral.js",
        "content/sites/generic.js",
        "content/radar.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
